{
	"$help": "https://aka.ms/terminal-documentation",
	"$schema": "https://aka.ms/terminal-profiles-schema",
	"language": "en-US",
	"theme": "system",
	"centerOnLaunch": true,
	"alwaysShowNotificationIcon": true,
	"showTabsFullscreen": true,
	"useAcrylicInTabRow": true,
	"snapToGridOnResize": true,
	"windowingBehavior": "useExisting",
	"newTabPosition": "afterCurrentTab",
	"copyOnSelect": true,
	"actions": [],
	"keybindings": [
		{ "id": "Terminal.OpenNewTab", "keys": "alt+shift+t" },
		{ "id": "Terminal.PrevTab", "keys": "alt+shift+[" },
		{ "id": "Terminal.NextTab", "keys": "alt+shift+]" },
		{ "id": "Terminal.DuplicatePaneRight", "keys": "alt+shift+\\" },
		{ "id": "Terminal.DuplicatePaneDown", "keys": "alt+shift+minus" },
		{ "id": "Terminal.ClosePane", "keys": "alt+shift+c" },
		{ "id": "Terminal.MoveFocusDown", "keys": "alt+j" },
		{ "id": "Terminal.MoveFocusUp", "keys": "alt+k" },
		{ "id": "Terminal.MoveFocusLeft", "keys": "alt+h" },
		{ "id": "Terminal.MoveFocusRight", "keys": "alt+l" },
		{ "id": "Terminal.ResizePaneDown", "keys": "alt+shift+j" },
		{ "id": "Terminal.ResizePaneUp", "keys": "alt+shift+k" },
		{ "id": "Terminal.ResizePaneLeft", "keys": "alt+shift+h" },
		{ "id": "Terminal.ResizePaneRight", "keys": "alt+shift+l" }
	],
	"defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
	"profiles": {
		"defaults": {
			"colorScheme": {
				"dark": "Tango Dark",
				"light": "Tango Light"
			},
			"useAcrylic": true,
			"opacity": 60,
			"showMarksOnScrollbar": true,
			"cursorShape": "filledBox",
			"font": {
				"face": "Maple Mono NF CN",
				"size": 14,
				"features": {
					"ss03": 0
				}
			},
			"historySize": 10000,
			"experimental.repositionCursorWithMouse": true,
			"experimental.rightClickContextMenu": true
		},
		"list": []
	},
	"schemes": []
}